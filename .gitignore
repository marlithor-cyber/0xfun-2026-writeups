# Ignore everything by default in this workspace-style repo.
*

# Keep git metadata and top-level docs/config.
!.gitignore
!README.md

# Keep writeup directories and selected files inside them.
!crypto/
crypto/*
!crypto/90/
crypto/90/*
!crypto/90/README.md
!crypto/90/solve.py
!crypto/90/cipher.txt
!crypto/90/solve.png
!crypto/BitStorm/
crypto/BitStorm/*
!crypto/BitStorm/README.md
!crypto/BitStorm/solve.py
!crypto/BitStorm/output.txt
!crypto/fortune/
crypto/fortune/*
!crypto/fortune/README.md
!crypto/fortune/solve.cpp
!crypto/fortune_revenge/
crypto/fortune_revenge/*
!crypto/fortune_revenge/README.md
!crypto/fortune_revenge/solve.py
!crypto/Hawk_II/
crypto/Hawk_II/*
!crypto/Hawk_II/README.md
!crypto/Hawk_II/solve.py
!crypto/Hawk_II/output.txt

# Common generated files.
__pycache__/
*.pyc
