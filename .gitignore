# Ignore everything by default in this workspace-style repo.
*

# Keep git metadata and top-level docs/config.
!.gitignore
!README.md

# Keep writeup directories and selected files inside them.
!crypto/
crypto/*
!crypto/90/
crypto/90/*
!crypto/90/README.md
!crypto/90/solve.py
!crypto/90/cipher.txt
!crypto/90/solve.png

# Common generated files.
__pycache__/
*.pyc
